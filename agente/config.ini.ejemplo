[api]
url   = https://www.pafirma.com
token = PEGUE-AQUI-EL-MISMO-TOKEN-QUE-EN-RENDER   ; AGENTE_CONTPAQ_TOKEN

; Una sección por empresa. El RFC conecta con el cliente del sistema.
[empresa:Grupo Norte]
